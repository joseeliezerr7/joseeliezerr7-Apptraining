    "updatedAt": "2026-05-13",
    "termsLink": "Terms of service",
    "privacyLink": "Privacy policy",
    "terms": {
      "title": "Terms of service",
      "sections": [
        {
          "heading": "1. Acceptance",
          "body": "By creating an account or using this app you agree to be bound by these terms. If you do not agree, do not use the service."
        },
        {
          "heading": "2. Your account",
          "body": "You are responsible for keeping your credentials secure and for all activity in your account. Notify us immediately of any unauthorized access."
        },
        {
          "heading": "3. Content",
          "body": "All training videos, manuals and materials provided through the app are licensed for personal, non-commercial use. You may not redistribute, resell or extract them."
        },
        {
          "heading": "4. Acceptable use",
          "body": "Do not use the service to upload illegal content, harass other users, attempt to break or reverse-engineer the system, or scrape content automatically."
        },
        {
          "heading": "5. Termination",
          "body": "We may suspend or terminate accounts that violate these terms. You may delete your account at any time from Profile > Delete account."
        },
        {
          "heading": "6. Disclaimer",
          "body": "The service is provided 'as is' without warranties of any kind. We are not liable for indirect or consequential damages."
        },
        {
          "heading": "7. Contact",
          "body": "Questions about these terms? Reach us at legal@example.com."
        }
      ]
    },
    "privacy": {
      "title": "Privacy policy",
      "sections": [
        {
          "heading": "1. Data we collect",
          "body": "We collect the data you provide at sign-up (name, email, country, optional phone), authentication metadata, and basic usage signals such as which videos and manuals you open."
        },
        {
          "heading": "2. How we use it",
          "body": "We use your data to authenticate you, personalize your experience, recommend training content and respond to support requests."
        },
        {
          "heading": "3. Storage and security",
          "body": "Data is stored with our backend provider (Supabase) under industry-standard encryption in transit and at rest. Sessions on mobile devices are stored in secure platform storage."
        },
        {
          "heading": "4. Sharing",
          "body": "We do not sell your data. We share it only with processors necessary to run the service (authentication, hosting, storage)."
        },
        {
          "heading": "5. Your rights",
          "body": "You can edit your profile from the app, change your password, or delete your account permanently. Contact us to request a data export."
        },
        {
          "heading": "6. Children",
          "body": "This service is not directed to children under 13. If you believe a child has registered, contact us to have the account removed."
        },
        {
          "heading": "7. Contact",
          "body": "Privacy questions: privacy@example.com."
        }
      ]
    }
  },
